<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🤖 محرر بوتات تلجرام</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: #fff;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2em;
            background: linear-gradient(45deg, #0088cc, #00cc88);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .main-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 12px 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #ccc;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 14px;
        }

        .tab-btn.active {
            background: linear-gradient(45deg, #0088cc, #006699);
            color: white;
            border-color: transparent;
        }

        .tab-btn:hover {
            background: rgba(0, 136, 204, 0.3);
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.3s;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .editor-area {
            width: 100%;
            min-height: 300px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: #fff;
            padding: 20px;
            font-family: 'Consolas', 'Courier New', monospace;
            font-size: 14px;
            resize: vertical;
            direction: ltr;
        }

        .editor-area::placeholder {
            color: #666;
        }

        .btn {
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(45deg, #0088cc, #006699);
            color: white;
        }

        .btn-success {
            background: linear-gradient(45deg, #4CAF50, #45a049);
            color: white;
        }

        .btn-danger {
            background: linear-gradient(45deg, #f44336, #d32f2f);
            color: white;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin: 15px 0;
        }

        .result-box {
            margin-top: 15px;
            padding: 15px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-height: 300px;
            overflow-y: auto;
        }

        .color-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 15px;
            margin: 15px 0;
        }

        .color-card {
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: bold;
            color: white;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }

        .color-card:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

        .color-red { background: linear-gradient(135deg, #ff4444, #cc0000); }
        .color-blue { background: linear-gradient(135deg, #4444ff, #0000cc); }
        .color-green { background: linear-gradient(135deg, #44ff44, #00cc00); }
        .color-purple { background: linear-gradient(135deg, #aa44ff, #6600cc); }
        .color-orange { background: linear-gradient(135deg, #ffaa00, #cc8800); }
        .color-cyan { background: linear-gradient(135deg, #00aaaa, #008888); }

        .button-item {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            margin: 10px 0;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .error-item {
            padding: 12px;
            margin: 8px 0;
            border-radius: 8px;
            border-right: 4px solid;
        }

        .error-item.error {
            background: rgba(244, 67, 54, 0.1);
            border-color: #f44336;
        }

        .error-item.warning {
            background: rgba(255, 152, 0, 0.1);
            border-color: #ff9800;
        }

        .input-group {
            display: flex;
            gap: 10px;
            margin: 15px 0;
        }

        .input-group input {
            flex: 1;
            padding: 12px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            color: white;
            font-size: 14px;
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 25px;
            border-radius: 10px;
            color: white;
            animation: slideIn 0.3s;
            z-index: 1000;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .notification.success { background: #4CAF50; }
        .notification.error { background: #f44336; }

        .stats {
            display: flex;
            gap: 20px;
            margin: 15px 0;
            flex-wrap: wrap;
        }

        .stat-card {
            flex: 1;
            min-width: 120px;
            padding: 15px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🤖 محرر بوتات تلجرام المتقدم</h1>
            <p style="color: #888; margin-top: 10px;">عدل كود بوتك بسهولة | لون الأزرار | اكتشف الأخطاء</p>
        </div>

        <div class="main-card">
            <!-- التبويبات -->
            <div class="tabs">
                <button class="tab-btn active" onclick="switchTab('editor')">📝 المحرر</button>
                <button class="tab-btn" onclick="switchTab('buttons')">🔘 الأزرار</button>
                <button class="tab-btn" onclick="switchTab('colors')">🎨 الألوان</button>
                <button class="tab-btn" onclick="switchTab('errors')">🔍 الأخطاء</button>
                <button class="tab-btn" onclick="switchTab('token')">🔑 التوكن</button>
            </div>

            <!-- المحرر -->
            <div id="editor-tab" class="tab-content active">
                <textarea id="codeEditor" class="editor-area" placeholder="ألصق كود البوت هنا..."></textarea>
                <div class="action-buttons">
                    <button class="btn btn-primary" onclick="analyzeCode()">🔍 تحليل الكود</button>
                    <button class="btn btn-success" onclick="saveToFile()">💾 حفظ الملف</button>
                    <button class="btn btn-primary" onclick="loadFromFile()">📂 فتح ملف</button>
                    <button class="btn btn-primary" onclick="formatCode()">✨ تنسيق الكود</button>
                </div>
                <div class="stats" id="codeStats">
                    <div class="stat-card">📏 الأسطر: <strong id="lineCount">0</strong></div>
                    <div class="stat-card">🔘 الأزرار: <strong id="buttonCount">0</strong></div>
                    <div class="stat-card">⚠️ الأخطاء: <strong id="errorCount">0</strong></div>
                </div>
                <div class="result-box" id="editorResult" style="display:none;"></div>
            </div>

            <!-- الأزرار -->
            <div id="buttons-tab" class="tab-content">
                <div class="action-buttons">
                    <button class="btn btn-primary" onclick="scanButtons()">🔍 فحص الأزرار</button>
                    <button class="btn btn-success" onclick="addNewButton()">➕ إضافة زر</button>
                </div>
                <div class="input-group" id="newButtonForm" style="display:none;">
                    <input type="text" id="btnText" placeholder="نص الزر">
                    <input type="text" id="btnCallback" placeholder="callback_data">
                    <button class="btn btn-primary" onclick="insertButton()">إدراج</button>
                </div>
                <div id="buttonsList"></div>
            </div>

            <!-- الألوان -->
            <div id="colors-tab" class="tab-content">
                <h3>اختر لون الأزرار:</h3>
                <div class="color-grid">
                    <div class="color-card color-red" onclick="applyColor('red')">🔴 أحمر</div>
                    <div class="color-card color-blue" onclick="applyColor('blue')">🔵 أزرق</div>
                    <div class="color-card color-green" onclick="applyColor('green')">🟢 أخضر</div>
                    <div class="color-card color-purple" onclick="applyColor('purple')">🟣 بنفسجي</div>
                    <div class="color-card color-orange" onclick="applyColor('orange')">🟠 برتقالي</div>
                    <div class="color-card color-cyan" onclick="applyColor('cyan')">🔵 سماوي</div>
                </div>
                <div id="colorResult" class="result-box" style="display:none;"></div>
            </div>

            <!-- الأخطاء -->
            <div id="errors-tab" class="tab-content">
                <div class="action-buttons">
                    <button class="btn btn-primary" onclick="checkErrors()">🔍 فحص الأخطاء</button>
                    <button class="btn btn-warning" onclick="autoFixErrors()">🪄 إصلاح تلقائي</button>
                </div>
                <div id="errorsList"></div>
            </div>

            <!-- التوكن -->
            <div id="token-tab" class="tab-content">
                <h3>تغيير توكن البوت:</h3>
                <div class="input-group">
                    <input type="text" id="newToken" placeholder="أدخل التوكن الجديد...">
                    <button class="btn btn-primary" onclick="changeToken()">تحديث التوكن</button>
                </div>
                <div id="tokenResult" class="result-box" style="display:none;"></div>
            </div>
        </div>
    </div>

    <input type="file" id="fileInput" style="display:none;" accept=".py">

    <script>
        // ====== تبديل التبويبات ======
        function switchTab(tabName) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(tabName + '-tab').classList.add('active');
        }

        // ====== تحليل الكود ======
        function analyzeCode() {
            const code = getCode();
            const lines = code.split('\n').length;
            const buttons = extractButtons(code);
            const errors = detectErrors(code);
            
            document.getElementById('lineCount').textContent = lines;
            document.getElementById('buttonCount').textContent = buttons.length;
            document.getElementById('errorCount').textContent = errors.length;
            
            showNotification('✅ تم تحليل الكود بنجاح', 'success');
        }

        // ====== استخراج الأزرار ======
        function extractButtons(code) {
            const buttons = [];
            const regex = /InlineKeyboardButton\s*\(\s*["']([^"']+)["']/g;
            let match;
            
            while ((match = regex.exec(code)) !== null) {
                if (!buttons.find(b => b.text === match[1])) {
                    buttons.push({ text: match[1], line: match.index });
                }
            }
            
            return buttons;
        }

        // ====== فحص الأزرار ======
        function scanButtons() {
            const code = getCode();
            const buttons = extractButtons(code);
            const listDiv = document.getElementById('buttonsList');
            
            if (buttons.length === 0) {
                listDiv.innerHTML = '<p style="color:#888; text-align:center; padding:20px;">لا توجد أزرار مكتشفة</p>';
                return;
            }
            
            listDiv.innerHTML = buttons.map(btn => `
                <div class="button-item">
                    <span>🔘 <strong>${btn.text}</strong></span>
                    <button class="btn btn-danger" onclick="deleteButton('${btn.text}')">حذف</button>
                </div>
            `).join('');
            
            showNotification(`✅ تم العثور على ${buttons.length} زر`, 'success');
        }

        // ====== إضافة زر جديد ======
        function addNewButton() {
            const form = document.getElementById('newButtonForm');
            form.style.display = form.style.display === 'none' ? 'flex' : 'none';
        }

        function insertButton() {
            const text = document.getElementById('btnText').value;
            const callback = document.getElementById('btnCallback').value || text;
            
            if (!text) {
                showNotification('❌ الرجاء إدخال نص الزر', 'error');
                return;
            }
            
            const buttonCode = `InlineKeyboardButton("${text}", callback_data="${callback}")`;
            const editor = document.getElementById('codeEditor');
            editor.value += '\n' + buttonCode;
            
            document.getElementById('btnText').value = '';
            document.getElementById('btnCallback').value = '';
            document.getElementById('newButtonForm').style.display = 'none';
            
            showNotification('✅ تمت إضافة الزر', 'success');
            analyzeCode();
        }

        // ====== حذف زر ======
        function deleteButton(buttonText) {
            const editor = document.getElementById('codeEditor');
            const regex = new RegExp(`.*${buttonText}.*\\n?`, 'g');
            editor.value = editor.value.replace(regex, '');
            scanButtons();
            showNotification('🗑️ تم حذف الزر', 'success');
        }

        // ====== تطبيق الألوان ======
        function applyColor(color) {
            const colorMap = {
                'red': '🔴',
                'blue': '🔵',
                'green': '🟢',
                'purple': '🟣',
                'orange': '🟠',
                'cyan': '🔵'
            };
            
            const emoji = colorMap[color];
            const editor = document.getElementById('codeEditor');
            let code = editor.value;
            
            // إضافة الإيموجي قبل نص الزر
            code = code.replace(
                /InlineKeyboardButton\s*\(\s*["']([^"']+)["']/g,
                `InlineKeyboardButton("${emoji} $1"`
            );
            
            editor.value = code;
            
            const resultDiv = document.getElementById('colorResult');
            resultDiv.style.display = 'block';
            resultDiv.innerHTML = `<p>✅ تم تلوين جميع الأزرار باللون ${color} ${emoji}</p>`;
            
            showNotification(`✅ تم تلوين الأزرار باللون ${color}`, 'success');
            analyzeCode();
        }

        // ====== اكتشاف الأخطاء ======
        function detectErrors(code) {
            const errors = [];
            
            // فحوصات أساسية
            if (!code.includes('import')) errors.push({ type: 'error', msg: 'لا يوجد استيراد للمكتبات' });
            if (!code.includes('Application') && !code.includes('Updater')) errors.push({ type: 'warning', msg: 'لم يتم العثور على إطار العمل' });
            if (!code.includes('TOKEN') && !code.includes('BOT_TOKEN')) errors.push({ type: 'warning', msg: 'لم يتم العثور على التوكن' });
            if (!code.includes('InlineKeyboardButton') && !code.includes('ReplyKeyboardMarkup')) errors.push({ type: 'warning', msg: 'لا توجد أزرار تفاعلية' });
            
            // فحص صحة الأقواس
            let openBrackets = 0;
            for (let char of code) {
                if (char === '(') openBrackets++;
                if (char === ')') openBrackets--;
            }
            if (openBrackets !== 0) errors.push({ type: 'error', msg: 'خطأ في الأقواس - عدد غير متطابق' });
            
            return errors;
        }

        function checkErrors() {
            const code = getCode();
            const errors = detectErrors(code);
            const listDiv = document.getElementById('errorsList');
            
            if (errors.length === 0) {
                listDiv.innerHTML = '<p style="color:#4CAF50; text-align:center; padding:20px;">✅ لا توجد أخطاء!</p>';
            } else {
                listDiv.innerHTML = errors.map(err => `
                    <div class="error-item ${err.type}">
                        ${err.type === 'error' ? '❌' : '⚠️'} ${err.msg}
                    </div>
                `).join('');
            }
            
            document.getElementById('errorCount').textContent = errors.filter(e => e.type === 'error').length;
            showNotification(`تم العثور على ${errors.length} مشكلة`, errors.length > 0 ? 'error' : 'success');
        }

        // ====== إصلاح تلقائي ======
        function autoFixErrors() {
            let code = getCode();
            let fixed = false;
            
            // إصلاح التوكن الناقص
            if (!code.includes('TOKEN') && !code.includes('BOT_TOKEN')) {
                code = 'BOT_TOKEN = "YOUR_TOKEN_HERE"\n' + code;
                fixed = true;
            }
            
            // إصلاح المكتبات الناقصة
            if (!code.includes('from telegram import')) {
                code = 'from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup\nfrom telegram.ext import Application, CommandHandler, CallbackQueryHandler\n\n' + code;
                fixed = true;
            }
            
            if (fixed) {
                document.getElementById('codeEditor').value = code;
                showNotification('✅ تم الإصلاح التلقائي', 'success');
            } else {
                showNotification('لم يتم العثور على أخطاء قابلة للإصلاح التلقائي', 'error');
            }
            
            checkErrors();
        }

        // ====== تغيير التوكن ======
        function changeToken() {
            const newToken = document.getElementById('newToken').value;
            if (!newToken) {
                showNotification('❌ الرجاء إدخال التوكن', 'error');
                return;
            }
            
            let code = getCode();
            code = code.replace(/TOKEN\s*=\s*["'][^"']*["']/g, `TOKEN = "${newToken}"`);
            code = code.replace(/BOT_TOKEN\s*=\s*["'][^"']*["']/g, `BOT_TOKEN = "${newToken}"`);
            
            document.getElementById('codeEditor').value = code;
            
            const resultDiv = document.getElementById('tokenResult');
            resultDiv.style.display = 'block';
            resultDiv.innerHTML = `<p>✅ تم تحديث التوكن بنجاح</p><p style="color:#888;">التوكن الجديد: ${newToken.substring(0, 15)}...</p>`;
            
            showNotification('✅ تم تحديث التوكن', 'success');
        }

        // ====== تنسيق الكود ======
        function formatCode() {
            let code = getCode();
            // تنسيق بسيط
            code = code.replace(/\n{3,}/g, '\n\n'); // إزالة الأسطر الفارغة الزائدة
            document.getElementById('codeEditor').value = code;
            showNotification('✨ تم تنسيق الكود', 'success');
        }

        // ====== حفظ وتحميل الملفات ======
        function saveToFile() {
            const code = getCode();
            const blob = new Blob([code], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'bot_code.py';
            a.click();
            URL.revokeObjectURL(url);
            showNotification('💾 تم حفظ الملف', 'success');
        }

        function loadFromFile() {
            document.getElementById('fileInput').click();
        }

        document.getElementById('fileInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('codeEditor').value = e.target.result;
                    analyzeCode();
                    showNotification('📂 تم فتح الملف', 'success');
                };
                reader.readAsText(file);
            }
        });

        // ====== دوال مساعدة ======
        function getCode() {
            return document.getElementById('codeEditor').value;
        }

        function showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.textContent = message;
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        // ====== تحليل تلقائي عند تحميل الصفحة ======
        document.getElementById('codeEditor').addEventListener('input', function() {
            analyzeCode();
        });
    </script>
</body>
</html>  
